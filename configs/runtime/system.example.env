# TRACE system configuration template.
# Copy this file to configs/runtime/system.local.env and edit it on your server.
# Do NOT commit system.local.env.

# Repository and conda
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
CONDA_DIR="${CONDA_DIR:-$HOME/miniconda3}"

# PostgreSQL for HoloClean
TRACE_ENABLE_POSTGRES="${TRACE_ENABLE_POSTGRES:-1}"
PG_DB="${PG_DB:-holo}"
PG_USER="${PG_USER:-holocleanuser}"
PG_PASSWORD="${PG_PASSWORD:-change_me}"

# MySQL / optional connector settings
TRACE_ENABLE_MYSQL="${TRACE_ENABLE_MYSQL:-0}"
MYSQL_DB="${MYSQL_DB:-mydb}"
MYSQL_ROOT_PASSWORD="${MYSQL_ROOT_PASSWORD:-change_me}"

# Optional setup switches
TRACE_INSTALL_SYSTEM_PACKAGES="${TRACE_INSTALL_SYSTEM_PACKAGES:-0}"
TRACE_INSTALL_HOLOCLEAN="${TRACE_INSTALL_HOLOCLEAN:-1}"
TRACE_INSTALL_BOOSTCLEAN="${TRACE_INSTALL_BOOSTCLEAN:-1}"